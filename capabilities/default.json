{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Grants access to core Tauri APIs and the ADB bridge commands for all windows.",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-zoom",
    "allow-adb-connect",
    "allow-adb-write",
    "allow-adb-ack",
    "allow-adb-close"
  ]
}
