{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Grants access to core Tauri APIs and the ADB bridge commands for all windows.",
  "windows": ["*"],
  "remote": {
    "urls": ["https://*", "http://*", "https://*:*", "http://*:*", "mbf://*"]
  },
  "permissions": [
    "core:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:webview:allow-set-webview-zoom",
    "allow-adb-connect",
    "allow-adb-write",
    "allow-adb-ack",
    "allow-adb-close"
  ]
}
