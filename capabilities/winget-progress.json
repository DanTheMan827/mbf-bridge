{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "winget-progress",
  "description": "Grants the winget-progress window access to close itself via the close_winget_progress_window command.",
  "windows": ["winget-progress"],
  "remote": {
    "urls": ["mbf://localhost/winget-progress"]
  },
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "allow-close-winget-progress-window",
    "allow-open-main-window"
  ]
}
